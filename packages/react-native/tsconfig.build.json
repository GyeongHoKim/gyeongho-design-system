{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@ghds/tsconfig/react-native-library",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/test-utils.tsx",
    "src/test/**"
  ]
}
