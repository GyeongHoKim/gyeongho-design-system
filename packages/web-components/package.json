{
  "name": "@ghds/web-components",
  "version": "0.9.0",
  "description": "Framework-agnostic hand-drawn (sketchy) web components for GHDS, authored with Lit. Outlines from @ghds/sketch-core, design values from @ghds/tokens.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GyeongHoKim/gyeongho-design-system.git",
    "directory": "packages/web-components"
  },
  "keywords": [
    "design-system",
    "web-components",
    "custom-elements",
    "lit",
    "sketchy",
    "hand-drawn",
    "ghds"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/index.mjs",
    "./dist/index.cjs"
  ],
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check-types": "tsc --noEmit -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@ghds/icons": "workspace:*",
    "@ghds/sketch-core": "workspace:*",
    "@ghds/tokens": "workspace:*",
    "lit": "catalog:"
  },
  "devDependencies": {
    "@ghds/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "jsdom": "^25.0.1",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}