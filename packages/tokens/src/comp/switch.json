{
  "comp": {
    "switch": {
      "$description": "Tier 3 component tokens for the hand-drawn Switch. References sys only.",
      "track": {
        "$type": "dimension",
        "width": { "$value": "{sys.spacing.2xl}" },
        "height": { "$value": "{sys.icon.size.md}" }
      },
      "thumb": {
        "size": { "$type": "dimension", "$value": "{sys.icon.size.sm}" },
        "inset": { "$type": "dimension", "$value": "{sys.spacing.xs}" },
        "color": {
          "$type": "color",
          "default": { "$value": "{sys.color.bg.surface}" },
          "disabled": { "$value": "{sys.color.bg.muted}" }
        }
      },
      "bg": {
        "$type": "color",
        "off": {
          "default": { "$value": "{sys.color.bg.muted}" },
          "disabled": { "$value": "{sys.color.bg.subtle}" }
        },
        "on": {
          "default": { "$value": "{sys.color.bg.primary.default}" },
          "hover": { "$value": "{sys.color.bg.primary.hover}" },
          "disabled": { "$value": "{sys.color.bg.primary.disabled}" }
        }
      },
      "stroke": {
        "$type": "color",
        "default": { "$value": "{sys.color.border.default}" },
        "checked": { "$value": "{sys.color.bg.primary.active}" },
        "focus": { "$value": "{sys.color.border.focus}" },
        "disabled": { "$value": "{sys.color.border.subtle}" }
      },
      "text": {
        "$type": "color",
        "label": { "$value": "{sys.color.text.primary}" },
        "disabled": { "$value": "{sys.color.text.disabled}" }
      },
      "gap": { "$type": "dimension", "$value": "{sys.spacing.xs}" },
      "sketch": {
        "$type": "number",
        "roughness": { "$value": "{sys.sketch.roughness}" },
        "bowing": { "$value": "{sys.sketch.bowing}" }
      }
    }
  }
}
