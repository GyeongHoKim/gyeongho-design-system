{
  "name": "@ghds/react",
  "version": "0.9.0",
  "description": "Hand-drawn (sketchy) React component library for GHDS — token-driven visuals rendered from @ghds/sketch-core.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GyeongHoKim/gyeongho-design-system.git",
    "directory": "packages/react"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "sketchy",
    "hand-drawn",
    "ui",
    "ghds"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check-types": "tsc --noEmit -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.8",
    "@ghds/icons": "workspace:*",
    "@ghds/sketch-core": "workspace:*",
    "@ghds/tokens": "workspace:*",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0"
  },
  "devDependencies": {
    "@ghds/tsconfig": "workspace:*",
    "@storybook/react-vite": "^9.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^9.1.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}