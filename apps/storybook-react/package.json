{
  "name": "storybook-react",
  "version": "0.0.14",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test-storybook": "vitest --project=storybook",
    "vrt:capture": "storycap --serverCmd \"http-server storybook-static -p 9001 -s\" http://localhost:9001 -o .reg/images -f --disableCssAnimation --puppeteerLaunchConfig \"{\\\"args\\\":[\\\"--no-sandbox\\\",\\\"--disable-setuid-sandbox\\\",\\\"--disable-dev-shm-usage\\\",\\\"--force-prefers-reduced-motion\\\"]}\"",
    "vrt": "reg-suit run",
    "clean": "rm -rf storybook-static .turbo node_modules/.cache .reg",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-kr": "catalog:",
    "@fontsource-variable/nunito-sans": "catalog:",
    "@fontsource/gaegu": "catalog:",
    "@fontsource/gochi-hand": "catalog:",
    "@fontsource/pretendard": "catalog:",
    "@ghds/icons": "workspace:*",
    "@ghds/react": "workspace:*",
    "@ghds/tokens": "workspace:*"
  },
  "devDependencies": {
    "@ghds/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^9.1.0",
    "@storybook/addon-docs": "^9.1.0",
    "@storybook/addon-vitest": "^9.1.0",
    "@storybook/react-vite": "^9.1.0",
    "@types/node": "catalog:",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/browser": "catalog:",
    "http-server": "catalog:",
    "playwright": "catalog:",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reg-keygen-git-hash-plugin": "catalog:",
    "reg-notify-github-with-api-plugin": "catalog:",
    "reg-publish-s3-plugin": "catalog:",
    "reg-suit": "catalog:",
    "storybook": "^9.1.0",
    "storycap": "catalog:",
    "typescript": "catalog:",
    "vite": "^6.0.0",
    "vitest": "catalog:"
  }
}
