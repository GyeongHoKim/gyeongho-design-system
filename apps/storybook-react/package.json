{
  "name": "storybook-react",
  "version": "0.0.11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test-storybook": "vitest --project=storybook",
    "clean": "rm -rf storybook-static .turbo node_modules/.cache",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-kr": "catalog:",
    "@fontsource-variable/nunito-sans": "catalog:",
    "@fontsource/gaegu": "catalog:",
    "@fontsource/gochi-hand": "catalog:",
    "@fontsource/pretendard": "catalog:",
    "@ghds/icons": "workspace:*",
    "@ghds/react": "workspace:*",
    "@ghds/tokens": "workspace:*"
  },
  "devDependencies": {
    "@ghds/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^9.1.0",
    "@storybook/addon-docs": "^9.1.0",
    "@storybook/addon-vitest": "^9.1.0",
    "@storybook/react-vite": "^9.1.0",
    "@types/node": "catalog:",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/browser": "catalog:",
    "chromatic": "catalog:",
    "playwright": "catalog:",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^9.1.0",
    "typescript": "catalog:",
    "vite": "^6.0.0",
    "vitest": "catalog:"
  }
}
