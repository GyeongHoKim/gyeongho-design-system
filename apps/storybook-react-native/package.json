{
  "name": "@ghds/storybook-react-native",
  "version": "0.0.14",
  "private": true,
  "description": "Web-based Storybook for @ghds/react-native (react-native-web).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "test-storybook": "vitest --project=storybook",
    "vrt:capture": "storycap --serverCmd \"http-server storybook-static -p 9003 -s\" http://localhost:9003 -o .reg/images -f --disableCssAnimation --puppeteerLaunchConfig \"{\\\"args\\\":[\\\"--no-sandbox\\\",\\\"--disable-setuid-sandbox\\\",\\\"--disable-dev-shm-usage\\\",\\\"--force-prefers-reduced-motion\\\"]}\"",
    "vrt": "reg-suit run",
    "clean": "rm -rf storybook-static .turbo .reg",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@ghds/icons": "workspace:*",
    "@ghds/react-native": "workspace:*",
    "@shopify/restyle": "^2.4.5"
  },
  "devDependencies": {
    "@ghds/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^9.0.0",
    "@storybook/addon-vitest": "^9.0.0",
    "@storybook/react": "^9.0.0",
    "@storybook/react-native-web-vite": "^9.0.0",
    "@types/node": "catalog:",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitest/browser": "catalog:",
    "http-server": "catalog:",
    "playwright": "catalog:",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.79.0",
    "react-native-svg": "^15.0.0",
    "react-native-web": "^0.20.0",
    "reg-keygen-git-hash-plugin": "catalog:",
    "reg-notify-github-with-api-plugin": "catalog:",
    "reg-publish-s3-plugin": "catalog:",
    "reg-suit": "catalog:",
    "storybook": "^9.0.0",
    "storycap": "catalog:",
    "typescript": "catalog:",
    "vite": "^7.0.0",
    "vitest": "catalog:"
  }
}
