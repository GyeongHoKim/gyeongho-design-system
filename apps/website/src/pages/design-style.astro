---
import BaseLayout from '../layouts/BaseLayout.astro';
import { designStyle } from '../lib/tokens';

// All data below is DERIVED from @ghds/tokens at build time — nothing is
// hand-copied. Change a token and this page regenerates.
const palette = designStyle.palette();
const colors = designStyle.semanticColors();
const typography = designStyle.typography();
const spacing = designStyle.spacing();
const radius = designStyle.radius();
const shadow = designStyle.shadow();
---

<BaseLayout
  title="Design Style"
  description="Color, typography, spacing, radius, and shadow design tokens generated automatically from @ghds/tokens."
>
  <section class="page-intro">
    <span class="eyebrow">Design Style</span>
    <h1>Design Style</h1>
    <p>
      Every value on this page is read directly from the <code>@ghds/tokens</code> build output.
      Nothing here is hand-copied — when a token changes, this page updates with it. Each swatch
      uses the generated CSS variable (<code>var(--…)</code>) directly, so dark mode is reflected
      instantly too.
    </p>
  </section>

  <section class="section">
    <h2>Reference Palette <code>ref.palette.*</code></h2>
    {
      palette.map((family) => (
        <div class="section">
          <p class="demo-label">{family.name}</p>
          <div class="swatch-grid">
            {family.swatches.map((swatch) => (
              <div class="swatch">
                <div class="chip" style={`background-color: var(${swatch.cssVar});`}></div>
                <div class="meta">
                  <div class="name">{swatch.path.replace('ref.palette.', '')}</div>
                  <div class="value">{swatch.value}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </section>

  <section class="section">
    <h2>Semantic Colors <code>sys.color.*</code></h2>
    <table class="token-table">
      <caption>Role-based colors. Values that differ in the dark theme are shown alongside.</caption>
      <thead>
        <tr>
          <th scope="col">Preview</th>
          <th scope="col">Token</th>
          <th scope="col">CSS Variable</th>
          <th scope="col">Light</th>
          <th scope="col">Dark</th>
        </tr>
      </thead>
      <tbody>
        {
          colors.map((token) => (
            <tr>
              <td>
                <span class="color-chip" style={`background-color: var(${token.cssVar});`} />
              </td>
              <td><code>{token.path}</code></td>
              <td><code>{token.cssVar}</code></td>
              <td><code>{token.value}</code></td>
              <td>{token.darkValue ? <code>{token.darkValue}</code> : '—'}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>

  <section class="section">
    <h2>Typography <code>sys.typography.*</code></h2>
    <div class="demo-stack">
      {
        typography.map((role) => (
          <div class="panel">
            <p class="demo-label">
              sys.typography.{role.role} — {role.fontSize} / {role.lineHeight} / {role.fontWeight}
            </p>
            <div
              style={`font-family: var(--sys-typography-${role.role}-fontFamily); font-size: var(--sys-typography-${role.role}-fontSize); line-height: var(--sys-typography-${role.role}-lineHeight); font-weight: var(--sys-typography-${role.role}-fontWeight);`}
            >
              The quick brown fox jumps over the lazy dog — 0123
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section">
    <h2>Spacing <code>sys.spacing.*</code></h2>
    <table class="token-table">
      <tbody>
        {
          spacing.map((token) => (
            <tr>
              <td>
                <span
                  class="token-sample-box"
                  style={`width: var(${token.cssVar}); height: 1rem;`}
                />
              </td>
              <td><code>{token.path}</code></td>
              <td><code>{token.value}</code></td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>

  <section class="section">
    <h2>Corner Radius <code>sys.radius.*</code></h2>
    <div class="demo-row">
      {
        radius.map((token) => (
          <div style="text-align:center;">
            <div class="token-radius-box" style={`border-radius: var(${token.cssVar});`} />
            <div class="value" style="margin-top: var(--sys-spacing-xs);">
              <code>{token.path.replace('sys.radius.', '')}</code> · {token.value}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section">
    <h2 id="shadow">Shadow <code>sys.shadow.*</code></h2>
    <div class="demo-row" style="gap: var(--sys-spacing-lg);">
      {
        shadow.map((token) => (
          <div style="text-align:center;">
            <div class="token-shadow-box" style={`box-shadow: var(${token.cssVar});`} />
            <div class="value" style="margin-top: var(--sys-spacing-sm);">
              <code>{token.path.replace('sys.shadow.', '')}</code>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
