---
import LitDemo from '../components/LitDemo.astro';
import ReactDemo from '../components/ReactDemo';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/withBase';
---

<BaseLayout
  title="Components"
  description="Live-renders React (@ghds/react) and Lit (@ghds/web-components) Button, Card, and Input side by side on one screen."
>
  <section class="page-intro">
    <span class="eyebrow">Components</span>
    <h1>Components</h1>
    <p>
      Compare two implementations that consume the same <code>@ghds/tokens</code> — a React
      component and a Lit web component — side by side on one screen. Color, spacing, radius, and
      typography come from the tokens, and the hand-drawn outlines come from
      <code>@ghds/sketch-core</code>. Toggle dark mode in the top-right corner and both respond
      identically.
    </p>
  </section>

  <section class="section">
    <div class="demo-columns">
      <div class="demo-column">
        <h3>React <span class="demo-tag">@ghds/react</span></h3>
        {/* client:only — the sketch surface paints in the browser. */}
        <ReactDemo client:only="react" />
      </div>

      <div class="demo-column">
        <h3>Lit <span class="demo-tag">@ghds/web-components</span></h3>
        <LitDemo />
      </div>
    </div>
  </section>

  <section class="section panel">
    <h2>Cross-Framework, Single Token Source</h2>
    <p>
      The two columns use different runtimes (React's virtual DOM vs. native custom elements),
      but the visual result is identical. This is why tokens are kept as the single source of
      truth — change a value in one place, and every framework changes with it.
    </p>
  </section>

  <section class="section">
    <h2>Component Documentation</h2>
    <p>Anatomy, variants &amp; states, accessibility, props, and a live demo for each component:</p>
    <ul>
      <li>
        <a href={withBase('/components/button/')}>Button</a> — variants, states, accessibility,
        and props
      </li>
      <li>
        <a href={withBase('/components/card/')}>Card</a> — a generic hand-drawn surface container
      </li>
      <li>
        <a href={withBase('/components/input/')}>Input</a> — a labeled text field with an error
        state
      </li>
      <li>
        <a href={withBase('/components/textarea/')}>Textarea</a> — a multi-line text field with an
        opt-in auto-resize
      </li>
      <li>
        <a href={withBase('/components/checkbox/')}>Checkbox</a> — boolean input with an
        indeterminate state, plus CheckboxGroup
      </li>
      <li>
        <a href={withBase('/components/radio/')}>Radio</a> — single-selection input, used inside
        RadioGroup
      </li>
      <li>
        <a href={withBase('/components/switch/')}>Switch</a> — an immediate on/off toggle
      </li>
      <li>
        <a href={withBase('/accessibility/')}>Accessibility Guide</a> — keyboard interaction,
        focus management, and ARIA patterns shared across all components
      </li>
    </ul>
  </section>
</BaseLayout>
