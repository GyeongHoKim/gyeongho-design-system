---
import ButtonDemoLit from '../../components/demos/ButtonDemo.astro';
import ButtonDemoReact from '../../components/demos/ButtonDemo.tsx';
import CardDemoLit from '../../components/demos/CardDemo.astro';
import CardDemoReact from '../../components/demos/CardDemo.tsx';
import InputDemoLit from '../../components/demos/InputDemo.astro';
import InputDemoReact from '../../components/demos/InputDemo.tsx';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ACCESSIBILITY_GUIDE_LINK, COMPONENTS } from '../../lib/components';
import { withBase } from '../../lib/withBase';

const locale = 'en';
---

<BaseLayout
  title="Components"
  description="Live-renders React (@ghds/react) and Lit (@ghds/web-components) Button, Card, and Input side by side on one screen."
>
  <section class="page-intro">
    <span class="eyebrow">Components</span>
    <h1>Components</h1>
    <p>
      Compare two implementations that consume the same <code>@ghds/tokens</code> — a React
      component and a Lit web component — side by side on one screen. Color, spacing, radius, and
      typography come from the tokens, and the hand-drawn outlines come from
      <code>@ghds/sketch-core</code>. Toggle dark mode in the top-right corner and both respond
      identically.
    </p>
  </section>

  <section class="section">
    <div class="demo-columns">
      <div class="demo-column">
        <h3>React <span class="demo-tag">@ghds/react</span></h3>
        {/* client:only — the sketch surface paints in the browser. */}
        <div class="demo-stack">
          <div>
            <p class="demo-label">Button</p>
            <ButtonDemoReact client:only="react" />
          </div>
          <div>
            <p class="demo-label">Input</p>
            <InputDemoReact client:only="react" />
          </div>
          <div>
            <p class="demo-label">Card</p>
            <CardDemoReact client:only="react" />
          </div>
        </div>
      </div>

      <div class="demo-column">
        <h3>Lit <span class="demo-tag">@ghds/web-components</span></h3>
        <div class="demo-stack">
          <div>
            <p class="demo-label">Button</p>
            <ButtonDemoLit />
          </div>
          <div>
            <p class="demo-label">Input</p>
            <InputDemoLit />
          </div>
          <div>
            <p class="demo-label">Card</p>
            <CardDemoLit />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section panel">
    <h2>Cross-Framework, Single Token Source</h2>
    <p>
      The two columns use different runtimes (React's virtual DOM vs. native custom elements),
      but the visual result is identical. This is why tokens are kept as the single source of
      truth — change a value in one place, and every framework changes with it.
    </p>
  </section>

  <section class="section">
    <h2>Component Documentation</h2>
    <p>Anatomy, variants &amp; states, accessibility, props, and a live demo for each component:</p>
    <ul>
      {
        COMPONENTS.map((component) => (
          <li>
            <a href={withBase(`/components/${component.slug}/`)}>{component.label}</a> —{' '}
            {component.summary[locale]}
          </li>
        ))
      }
      <li>
        <a href={withBase(ACCESSIBILITY_GUIDE_LINK.href)}>
          {ACCESSIBILITY_GUIDE_LINK.label[locale]}
        </a> — {ACCESSIBILITY_GUIDE_LINK.summary[locale]}
      </li>
    </ul>
  </section>
</BaseLayout>
