---
import ButtonDemoLit from '../../components/demos/ButtonDemo.astro';
import ButtonDemoReact from '../../components/demos/ButtonDemo.tsx';
import CardDemoLit from '../../components/demos/CardDemo.astro';
import CardDemoReact from '../../components/demos/CardDemo.tsx';
import InputDemoLit from '../../components/demos/InputDemo.astro';
import InputDemoReact from '../../components/demos/InputDemo.tsx';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ACCESSIBILITY_GUIDE_LINK, COMPONENTS } from '../../lib/components';
import { withBase } from '../../lib/withBase';

const locale = 'ko';
---

<BaseLayout
  title="컴포넌트"
  description="React(@ghds/react)와 Lit(@ghds/web-components)의 Button, Card, Input을 한 화면에 나란히 라이브 렌더링해요."
>
  <section class="page-intro">
    <span class="eyebrow">컴포넌트</span>
    <h1>컴포넌트</h1>
    <p>
      같은 <code>@ghds/tokens</code>를 사용하는 두 구현체 — React 컴포넌트와 Lit 웹 컴포넌트 — 를
      한 화면에 나란히 비교해요. 색상, 간격, 반경, 타이포그래피는 토큰에서 가져오고, 손그림 윤곽선은
      <code>@ghds/sketch-core</code>에서 만들어져요. 우측 상단에서 다크 모드를 토글하면 두 컴포넌트 모두
      동일하게 반응해요.
    </p>
  </section>

  <section class="section">
    <div class="demo-columns">
      <div class="demo-column">
        <h3>React <span class="demo-tag">@ghds/react</span></h3>
        {/* client:only — the sketch surface paints in the browser. */}
        <div class="demo-stack">
          <div>
            <p class="demo-label">Button</p>
            <ButtonDemoReact client:only="react" />
          </div>
          <div>
            <p class="demo-label">Input</p>
            <InputDemoReact client:only="react" />
          </div>
          <div>
            <p class="demo-label">Card</p>
            <CardDemoReact client:only="react" />
          </div>
        </div>
      </div>

      <div class="demo-column">
        <h3>Lit <span class="demo-tag">@ghds/web-components</span></h3>
        <div class="demo-stack">
          <div>
            <p class="demo-label">Button</p>
            <ButtonDemoLit />
          </div>
          <div>
            <p class="demo-label">Input</p>
            <InputDemoLit />
          </div>
          <div>
            <p class="demo-label">Card</p>
            <CardDemoLit />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section panel">
    <h2>크로스 프레임워크, 단일 토큰 소스</h2>
    <p>
      두 열은 다른 런타임(React의 가상 DOM vs. 네이티브 커스텀 엘리먼트)을 사용하지만,
      시각적 결과는 동일해요. 이것이 토큰을 단일 소스로 유지하는 이유예요 — 한 곳에서 값을 변경하면
      모든 프레임워크가 함께 변경돼요.
    </p>
  </section>

  <section class="section">
    <h2>컴포넌트 문서</h2>
    <p>각 컴포넌트의 구조, 변형 및 상태, 접근성, props 및 라이브 데모:</p>
    <ul>
      {
        COMPONENTS.map((component) => (
          <li>
            <a href={withBase(`/components/${component.slug}/`)}>{component.label}</a> —{' '}
            {component.summary[locale]}
          </li>
        ))
      }
      <li>
        <a href={withBase(ACCESSIBILITY_GUIDE_LINK.href)}>
          {ACCESSIBILITY_GUIDE_LINK.label[locale]}
        </a> — {ACCESSIBILITY_GUIDE_LINK.summary[locale]}
      </li>
    </ul>
  </section>
</BaseLayout>
