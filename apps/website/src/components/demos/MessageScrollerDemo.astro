---
// Live demo of `<gh-message-scroller>`: a bounded, auto-sticking chat log.
// The host's `max-height` is what makes it scroll; it pins the newest message
// while the reader is at the bottom. The module script registers the scroller
// plus the message, avatar, and bubble it stacks inside.
const LINES = [
  'Hey — are we still on for tomorrow?',
  'Yes! See you at 10.',
  'Should I bring anything?',
  'Just the slides, I think.',
  "Great, I'll print a few copies.",
  'Perfect. Coffee on me.',
  'Deal. See you then!',
  'One more thing — which room?',
  'The one on the third floor.',
  'Got it. Thanks!',
];
---

<gh-message-scroller style="max-height: 320px; max-width: 480px;">
  {
    LINES.map((text, index) => {
      const sent = index % 2 === 1;
      return (
        <gh-message side={sent ? 'sent' : 'received'}>
          <gh-avatar slot="avatar" name={sent ? 'Me' : 'Bo Ram'} />
          <span slot="author">{sent ? 'You' : 'Bo Ram'}</span>
          <span slot="timestamp">10:0{index}</span>
          <gh-bubble variant={sent ? 'sent' : 'received'}>{text}</gh-bubble>
        </gh-message>
      );
    })
  }
</gh-message-scroller>

<script>
  import '@ghds/web-components/message-scroller';
  import '@ghds/web-components/message';
  import '@ghds/web-components/avatar';
  import '@ghds/web-components/bubble';
</script>
