---
// Live Tabs demo (Lit).
---

<gh-tabs id="demo-tabs" label="Product details" style="max-width: 480px;"></gh-tabs>

<script>
  import '@ghds/web-components';
  const el = document.getElementById('demo-tabs');
  if (el) {
    (el as HTMLElement & { items: unknown }).items = [
      { value: 'overview', label: 'Overview', content: 'The overview panel.' },
      { value: 'specs', label: 'Specs', content: 'The specifications panel.' },
      { value: 'reviews', label: 'Reviews', content: 'The reviews panel.' },
    ];
    el.addEventListener('value-change', (e) => {
      (el as HTMLElement & { value: string }).value = (e as CustomEvent<string>).detail;
    });
  }
</script>
