---
// Live demo of a three-level breadcrumb trail (Lit).
---

<gh-breadcrumb id="demo-breadcrumb"></gh-breadcrumb>

<script>
  import '@ghds/web-components/breadcrumb';
  const el = document.getElementById('demo-breadcrumb');
  if (el) {
    (el as HTMLElement & { items: unknown }).items = [
      { label: 'Home', href: '#' },
      { label: 'Components', href: '#' },
      { label: 'Breadcrumb' },
    ];
  }
</script>
