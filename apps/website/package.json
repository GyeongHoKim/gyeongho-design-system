{
  "name": "@ghds/website",
  "version": "0.1.1",
  "private": true,
  "description": "GHDS promotional + documentation site (Astro) — KRDS-style IA, token-driven style pages, and live React/Lit component demos.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check-types": "tsc --noEmit --skipLibCheck",
    "clean": "rm -rf dist .astro .turbo node_modules/.cache"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/react": "^4.4.0",
    "@fontsource-variable/noto-sans-kr": "catalog:",
    "@fontsource-variable/nunito-sans": "catalog:",
    "@fontsource/gaegu": "catalog:",
    "@fontsource/gochi-hand": "catalog:",
    "@fontsource/pretendard": "catalog:",
    "@ghds/react": "workspace:*",
    "@ghds/tokens": "workspace:*",
    "@ghds/web-components": "workspace:*",
    "astro": "^5.16.0",
    "lit": "catalog:",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@ghds/tsconfig": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
