{
  "name": "ghds",
  "private": true,
  "description": "GH Design System — cross-platform component library and design tokens",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:storybook": "turbo run test-storybook",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "clean:all": "turbo run clean && rm -rf node_modules packages/*/node_modules apps/*/node_modules .turbo",
    "format": "turbo run format && biome format --write .",
    "check": "turbo run check",
    "check:fix": "turbo run check:fix",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "husky": "^9.1.7",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.9.0"
}
